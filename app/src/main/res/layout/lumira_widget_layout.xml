<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Top row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/widget_zodiac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="Leo"
            android:textColor="#AFA9EC"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="🔥 4"
            android:textColor="#AFA9EC"
            android:fontFamily="sans-serif-medium"
            android:textSize="11sp" />

    </RelativeLayout>

    <!-- Teaser text -->
    <TextView
        android:id="@+id/widget_teaser"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:text="Recognition finds you today."
        android:textColor="#EDE9FF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="2"
        android:gravity="center_vertical" />

    <!-- See why -->
    <TextView
        android:id="@+id/widget_see_why"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="See why →"
        android:textColor="#7F77DD"
        android:fontFamily="sans-serif-medium"
        android:textSize="11sp" />

</LinearLayout>